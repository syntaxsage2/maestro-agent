# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# 所有文件
[*]
# 使用 UTF-8 编码
charset = utf-8
# 使用 Unix 行结尾
end_of_line = lf
# 文件末尾添加空行
insert_final_newline = true
# 删除末尾空行
trim_trailing_whitespace = true

# TypeScript / JavaScript 文件
[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_style = space
indent_size = 2

# JSON 文件
[*.json]
indent_style = space
indent_size = 2

# Markdown 文件
[*.md]
indent_style = space
indent_size = 2
# Markdown 文件末尾空行强制删除
trim_trailing_whitespace = false

# HTML 文件
[*.html]
indent_style = space
indent_size = 2

# CSS 文件
[*.{css,scss,sass,less}]
indent_style = space
indent_size = 2

# YAML 文件
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# 配置文件
[{package.json,.eslintrc,.prettierrc}]
indent_style = space
indent_size = 2
